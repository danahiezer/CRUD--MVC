<h1> Lista de temas :v</h1>

<p>total de temas:{{temas.length}}</p>

<a href="/temas/crear">+ Agregar tema</a>

<ul> {{#each temas}}
  <li id="tema-{{_id}}">
    <strong>{{titulo}}</strong>
    — <span class="contador-votos">{{votos}}</span> votos

    <button class="btn-votar" data-id="{{_id}}"> Votar</button>

    <a href="/temas/{{_id}}/editar">Editar</a>


    <form action="/temas/{{_id}}/eliminar" method="POST" style="display:inline">
      <button type="submit">Eliminar</button>
    </form>
  </li>
  {{/each}}
</ul>
<script src="/js/votar.js"></script>