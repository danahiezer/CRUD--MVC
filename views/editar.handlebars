<h1>Editar tema</h1>

  <form action="/temas/{{tema._id}}/editar" method="POST">
    <label for="titulo">Título del tema:</label>
    <input type="text" id="titulo" name="titulo" value="{{tema.titulo}}">
    <button type="submit">Guardar cambios</button>
  </form>

  <a href="/temas">← Volver a la lista</a>

