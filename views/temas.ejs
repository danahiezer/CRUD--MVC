<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Learn It, Love It!</title>
</head>
<body>

  <h1>🎓 Learn It, Love It!</h1>

  <p>total de temas: <%= temas.length %></p>

 <a href="/temas/crear">+ Agregar tema</a>

  <ul>
    <% temas.forEach(tema => { %>
      <li>
        #<%= tema.id %> - <strong><%= tema.titulo %></strong>
        — <%= tema.votos %> votos

        <a href="/temas/<%= tema.id %>/editar">Editar</a>

        <form action="/temas/<%= tema.id %>/eliminar" method="POST" style="display:inline">
          <button type="submit">Eliminar</button>
        </form>
      </li>
    <% }) %>
  </ul>

</body>
</html>  